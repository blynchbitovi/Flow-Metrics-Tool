# Add your user email, API Token, and site URL for Jira here.
# You can get your API token from https://id.atlassian.com/manage-profile/security/api-tokens.
# Make sure to keep your .env file private and do not commit it to version control.
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

VITE_JIRA_EMAIL=you@example.com
VITE_JIRA_API_TOKEN=your-api-token-here
VITE_JIRA_SITE_URL=https://your-org.atlassian.net
